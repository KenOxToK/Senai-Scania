soma = 0
for i in range(10):
    numero = int(input("Digite um  numero: "))
    if i == 0:
        maior = numero
        menor = numero
    else:
            if numero > maior:
                maior = numero
                if numero < menor:
                    menor = numero
                    
                    soma += numero
media = soma / 10
print("Maior valor: ", maior)
print("Menor valor: ", menor)
print("Média: ", media)
